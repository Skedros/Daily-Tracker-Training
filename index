<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VFI Capital Markets Daily Tracker Training</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--navy:#0b1426;--navy2:#111e35;--gold:#c8a84b;--white:#fff;--off:rgba(255,255,255,.78);--muted:rgba(255,255,255,.38);--border:rgba(255,255,255,.08);--border2:rgba(255,255,255,.16);--green:#22c55e;--green-bg:rgba(34,197,94,.1);--red:#ef4444;--red-bg:rgba(239,68,68,.1);--amber:#f59e0b;--amber-bg:rgba(245,158,11,.1);--blue:#60a5fa;--blue-bg:rgba(96,165,250,.1);--slate:rgba(255,255,255,.055);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{font-family:Inter,sans-serif;background:var(--navy);color:var(--white);}
.deck{width:100vw;height:100vh;position:relative;overflow:hidden;}
.slide{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .3s;overflow:hidden;}
.slide.active{opacity:1;pointer-events:all;}
/* NAV */
.nav{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);z-index:100;display:flex;align-items:center;gap:14px;background:rgba(11,20,38,.93);border:1px solid var(--border2);backdrop-filter:blur(16px);padding:9px 20px;border-radius:50px;}
.nbtn{background:none;border:none;color:var(--muted);font-family:"IBM Plex Mono",monospace;font-size:12px;cursor:pointer;padding:4px 7px;transition:color .15s;}
.nbtn:hover{color:var(--white);}
.ndots{display:flex;gap:5px;align-items:center;}
.ndot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.18);cursor:pointer;transition:all .2s;}
.ndot.active{background:var(--gold);width:20px;border-radius:3px;}
.ncnt{font-family:"IBM Plex Mono",monospace;font-size:11px;color:var(--muted);}
/* LAYOUTS */
.sp{padding:48px 64px 76px;}
.sc{justify-content:center;align-items:center;text-align:center;}
/* TYPE */
.ey{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:11px;}
.txl{font-size:58px;font-weight:800;line-height:1;letter-spacing:-.02em;}
.tlg{font-size:42px;font-weight:800;line-height:1.05;letter-spacing:-.02em;}
.rule{width:46px;height:3px;background:var(--gold);border-radius:2px;}
/* CARDS */
.card{background:var(--slate);border:1px solid var(--border);border-radius:11px;padding:20px;}
.cgold{background:rgba(200,168,75,.06);border:1px solid rgba(200,168,75,.2);border-radius:11px;padding:19px 21px;}
.clbl{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px;}
.clg{color:var(--gold);}
.clam{color:var(--amber);}
.clb{color:var(--blue);}
.ctit{font-size:15px;font-weight:700;margin-bottom:6px;}
.cbody{font-size:13px;font-weight:300;color:var(--off);line-height:1.7;}
/* FORM MOCK ELEMENTS */
.fm-section{background:var(--navy);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:10px;}
.fm-head{background:rgba(255,255,255,.05);padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.fm-head-lbl{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;}
.fm-head-badge{font-family:"IBM Plex Mono",monospace;font-size:9px;color:var(--green);background:var(--green-bg);border:1px solid rgba(34,197,94,.2);padding:2px 8px;border-radius:3px;}
.fm-body{padding:14px 16px;}
.fm-grid{display:grid;gap:10px;}
.fm-field{display:flex;flex-direction:column;gap:4px;}
.fm-lbl{font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.04em;text-transform:uppercase;}
.fm-target{font-family:"IBM Plex Mono",monospace;font-size:10px;color:rgba(200,168,75,.7);}
.fm-val{background:rgba(255,255,255,.06);border:1px solid var(--border2);border-radius:6px;padding:9px 12px;font-family:"IBM Plex Mono",monospace;font-size:16px;font-weight:600;color:var(--white);}
.fm-val.hit{border-color:rgba(34,197,94,.3);background:rgba(34,197,94,.06);color:var(--green);}
.fm-val.new{border-color:rgba(200,168,75,.25);background:rgba(200,168,75,.05);color:var(--gold);}
.fm-bar{height:3px;background:rgba(255,255,255,.08);border-radius:2px;margin-top:4px;}
.fm-fill{height:100%;border-radius:2px;}
.fm-fill.hit{background:var(--green);}
.fm-fill.near{background:var(--amber);}
.fm-text{background:rgba(255,255,255,.06);border:1px solid var(--border2);border-radius:6px;padding:9px 12px;font-size:13px;color:var(--off);line-height:1.6;}
.fm-src-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.fm-src-lbl{font-size:12px;color:var(--muted);width:110px;flex-shrink:0;}
.fm-src-val{background:rgba(255,255,255,.06);border:1px solid var(--border2);border-radius:5px;padding:6px 11px;font-family:"IBM Plex Mono",monospace;font-size:14px;font-weight:600;color:var(--white);min-width:48px;text-align:center;}
.fm-other-entry{display:grid;grid-template-columns:60px 1fr;gap:8px;margin-bottom:7px;}
.fm-other-num{background:rgba(255,255,255,.06);border:1px solid var(--border2);border-radius:5px;padding:6px 10px;font-family:"IBM Plex Mono",monospace;font-size:14px;font-weight:600;color:var(--gold);text-align:center;}
.fm-other-desc{background:rgba(200,168,75,.05);border:1px solid rgba(200,168,75,.15);border-radius:5px;padding:6px 11px;font-size:12px;color:var(--gold);}
.fm-block-row{display:grid;grid-template-columns:22px 100px 1fr;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);}
.fm-block-row:last-child{border-bottom:none;padding-bottom:0;}
.fm-check{width:20px;height:20px;background:var(--navy2);border:1.5px solid var(--green);border-radius:4px;display:grid;place-items:center;font-size:11px;color:var(--green);flex-shrink:0;}
.fm-block-time{font-family:"IBM Plex Mono",monospace;font-size:11px;font-weight:600;color:var(--gold);line-height:1.3;}
.fm-block-note{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:5px;padding:7px 10px;font-family:"IBM Plex Mono",monospace;font-size:10px;color:var(--off);line-height:1.65;}
/* CALL ENTRY MOCK */
.fm-call{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:9px;padding:14px 16px;margin-bottom:10px;}
.fm-call:last-child{margin-bottom:0;}
.fm-call-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.fm-call-num{font-family:"IBM Plex Mono",monospace;font-size:10px;color:var(--muted);letter-spacing:.1em;}
.fm-call-fields{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;}
.fm-call-f{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:6px;padding:8px 10px;}
.fm-call-fl{font-size:9px;font-weight:600;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:3px;}
.fm-call-fv{font-size:13px;color:var(--white);font-weight:500;}
.fm-call-note{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:6px;padding:10px 12px;font-family:"IBM Plex Mono",monospace;font-size:11px;color:var(--off);line-height:1.7;margin-bottom:10px;}
.outcome-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
.oc{padding:5px 12px;border-radius:16px;font-family:"IBM Plex Mono",monospace;font-size:10px;font-weight:600;}
.oc-dim{background:rgba(255,255,255,.05);color:var(--muted);border:1px solid var(--border);}
.oc-g{background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,.25);}
.oc-r{background:var(--red-bg);color:var(--red);border:1px solid rgba(239,68,68,.22);}
.oc-a{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(245,158,11,.22);}
.oc-b{background:var(--blue-bg);color:var(--blue);border:1px solid rgba(96,165,250,.22);}
.oc-w{background:rgba(255,255,255,.07);color:var(--off);border:1px solid var(--border2);}
.oc-s{background:rgba(148,163,184,.1);color:rgba(148,163,184,.8);border:1px solid rgba(148,163,184,.2);}
.tog-row{display:flex;gap:5px;}
.tog{padding:5px 10px;border-radius:5px;font-size:10px;font-family:"IBM Plex Mono",monospace;font-weight:600;}
.tog-dim{background:rgba(255,255,255,.05);color:var(--muted);border:1px solid var(--border);}
.tog-y{background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,.25);}
.tog-n{background:var(--red-bg);color:var(--red);border:1px solid rgba(239,68,68,.22);}
.tog-na{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(245,158,11,.22);}
.tog-gd{background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,.25);}
/* PROGRESS TRAIL */
.trail{display:flex;align-items:center;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.trail-step{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:4px 11px;border-radius:4px;font-weight:600;}
.ts-done{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.2);}
.ts-cur{background:rgba(200,168,75,.12);color:var(--gold);border:1px solid rgba(200,168,75,.3);}
.ts-next{background:rgba(255,255,255,.04);color:var(--muted);border:1px solid var(--border);}
.trail-arr{color:var(--muted);font-size:11px;}
/* GHOST */
.ghost{font-size:180px;font-weight:900;color:rgba(255,255,255,.022);position:absolute;right:32px;top:-8px;line-height:1;letter-spacing:-.04em;pointer-events:none;user-select:none;}
/* PILL */
.pill{display:inline-flex;align-items:center;padding:4px 12px;border-radius:16px;font-family:"IBM Plex Mono",monospace;font-size:11px;font-weight:600;}
/* NOTES */
.np{position:fixed;bottom:76px;right:20px;width:286px;z-index:200;}
.np.col .nb{display:none;}
.nt{display:flex;align-items:center;justify-content:space-between;background:rgba(11,20,38,.96);border:1px solid rgba(200,168,75,.35);border-radius:8px 8px 0 0;padding:9px 13px;cursor:pointer;backdrop-filter:blur(12px);user-select:none;}
.np.col .nt{border-radius:8px;}
.ntl{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:7px;}
.nsd{width:6px;height:6px;border-radius:50%;background:var(--green);opacity:0;transition:opacity .3s;}
.nsd.show{opacity:1;}
.nar{font-size:9px;color:var(--muted);transition:transform .2s;}
.np:not(.col) .nar{transform:rotate(180deg);}
.nb{background:rgba(11,20,38,.97);border:1px solid rgba(200,168,75,.18);border-top:none;border-radius:0 0 8px 8px;}
.nta{width:100%;height:140px;background:transparent;border:none;color:rgba(255,255,255,.8);font-family:"IBM Plex Mono",monospace;font-size:12px;line-height:1.7;padding:12px 14px;resize:none;outline:none;}
.nta::placeholder{color:rgba(255,255,255,.16);}
.nft{display:flex;align-items:center;justify-content:space-between;padding:5px 10px 6px;border-top:1px solid var(--border);}
.nfl{font-family:"IBM Plex Mono",monospace;font-size:10px;color:var(--muted);}
.nbtn2{font-family:"IBM Plex Mono",monospace;font-size:10px;color:var(--muted);background:none;border:none;cursor:pointer;transition:color .15s;}
.nbtn2:hover{color:var(--red);}
.nva{width:100%;background:rgba(255,255,255,.03);border:none;border-top:1px solid var(--border);color:var(--muted);font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:8px;cursor:pointer;transition:all .15s;}
.nva:hover{background:rgba(255,255,255,.06);color:var(--white);}
/* MODAL */
.modal{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:300;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;backdrop-filter:blur(6px);}
.modal.open{opacity:1;pointer-events:all;}
.mbox{background:#0e1a2e;border:1px solid rgba(200,168,75,.2);border-radius:16px;width:600px;max-width:90vw;max-height:82vh;overflow-y:auto;padding:32px 36px;}
.mbox::-webkit-scrollbar{width:4px;}
.mbox::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:2px;}
.mhd{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;}
.mtit{font-size:20px;font-weight:700;}
.mcl{background:rgba(255,255,255,.06);border:1px solid var(--border2);color:var(--muted);font-family:"IBM Plex Mono",monospace;font-size:11px;padding:6px 13px;border-radius:6px;cursor:pointer;}
.mi{margin-bottom:18px;}
.msn{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.mnt{font-family:"IBM Plex Mono",monospace;font-size:12px;color:rgba(255,255,255,.7);line-height:1.7;background:rgba(255,255,255,.04);border-radius:7px;padding:12px 14px;white-space:pre-wrap;}
.ma{display:flex;gap:9px;margin-top:20px;border-top:1px solid var(--border);padding-top:16px;}
.mb2{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.06em;text-transform:uppercase;padding:8px 16px;border-radius:7px;cursor:pointer;border:none;transition:all .15s;}
.mc{background:rgba(200,168,75,.1);color:var(--gold);border:1px solid rgba(200,168,75,.2);}
.mc:hover{background:rgba(200,168,75,.18);}
.md{background:var(--red-bg);color:var(--red);border:1px solid rgba(239,68,68,.2);}
.md:hover{background:rgba(239,68,68,.18);}
</style>
</head>
<body>
<div class="deck">

<!-- S1 TITLE -->
<div class="slide active sc" style="background:var(--navy);">
  <div style="position:relative;z-index:2;max-width:660px;padding:40px;">
    <div style="width:52px;height:52px;background:var(--gold);border-radius:11px;display:grid;place-items:center;margin:0 auto 24px;font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:18px;color:var(--navy);">CM</div>
    <div class="ey" style="text-align:center;">VFI Capital Markets</div>
    <div class="txl" style="margin-bottom:14px;">Daily Tracker<br>Training</div>
    <div style="font-size:16px;font-weight:300;color:var(--muted);max-width:420px;margin:0 auto 28px;line-height:1.7;">We will build one complete day from start to finish. Every example uses the exact format you will fill out daily.</div>
    <div class="rule" style="margin:0 auto;"></div>
    <div style="margin-top:20px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:rgba(200,168,75,.5);letter-spacing:.1em;">REP: ALEX RIVERA &nbsp;&#183;&nbsp; MON MAY 4 2026</div>
  </div>
</div>

<!-- S2 WHY -->
<div class="slide sp" style="background:var(--navy);">
  <div class="ey">Purpose</div>
  <div class="tlg" style="margin-bottom:8px;">Why This Form Matters</div>
  <div style="font-size:14px;color:var(--muted);max-width:500px;margin-bottom:32px;">The tracker is the only window management has into your day. High call volume with no context tells us nothing.</div>
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;margin-bottom:24px;">
    <div class="card"><div class="clbl clg">01</div><div class="ctit">Visibility</div><div class="cbody">Call volume alone does not show whether your pipeline is healthy. The form gives context to the numbers.</div></div>
    <div class="card"><div class="clbl clg">02</div><div class="ctit">Coaching</div><div class="cbody">When the form is complete we can identify what is working and give you specific, targeted help.</div></div>
    <div class="card"><div class="clbl clg">03</div><div class="ctit">Your Record</div><div class="cbody">Every call you log is a permanent record of your work, your deals, and your activity over time.</div></div>
  </div>
  <div class="cgold">
    <div style="font-size:15px;color:var(--white);line-height:1.7;font-weight:400;"><strong>This is a two-way process.</strong> If something in the form does not reflect how you actually work, say it today. We will fix it.</div>
  </div>
</div>

<!-- S3 RULE -->
<div class="slide sp" style="background:var(--navy2);">
  <div class="ey">The Rule</div>
  <div class="tlg" style="margin-bottom:8px;">Fill It As It Happens</div>
  <div style="font-size:14px;color:var(--muted);margin-bottom:28px;">Open the form at 7AM. Keep it open all day. Log each call immediately after hanging up.</div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div style="background:var(--red-bg);border:1px solid rgba(239,68,68,.2);border-radius:11px;padding:24px;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--red);margin-bottom:13px;font-weight:600;">&#x2715; Wrong Way</div>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:13px;">
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.25);font-style:italic;">Call notes... (reconstructed from memory)</div>
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.25);font-style:italic;">Time block notes... (left blank)</div>
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.25);font-style:italic;">Other sources... (forgotten)</div>
      </div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--red);">Result: Missing details. Gaps in the record.</div>
    </div>
    <div style="background:var(--green-bg);border:1px solid rgba(34,197,94,.2);border-radius:11px;padding:24px;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--green);margin-bottom:13px;font-weight:600;">&#x2713; Right Way</div>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:13px;">
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:rgba(255,255,255,.8);line-height:1.6;">Follow Up Call: Called 512-884-3190 &#8212; SW Brian Castellano &#8212; Northland Capital &#8212; NGO, reach out in 30 days</div>
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:rgba(255,255,255,.8);">3 Presentations | 28 Calls | 11 Emails Sent</div>
        <div style="background:rgba(0,0,0,.2);border-radius:6px;padding:9px 12px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:rgba(255,255,255,.8);">General Emails Sent: 48</div>
      </div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--green);">Complete record. 60 seconds per call.</div>
    </div>
  </div>
  <div class="cgold" style="font-size:14px;color:var(--off);line-height:1.65;">We are going to build <strong style="color:var(--white);">Alex Rivera&#8217;s Monday, May 4</strong> from scratch &#8212; one section at a time &#8212; using the exact format the form requires.</div>
</div>

<!-- S4 DAILY METRICS -->
<div class="slide sp" style="background:var(--navy);position:relative;overflow:hidden;">
  <div class="ghost">02</div>
  <div class="trail"><span class="trail-step ts-cur">02 Daily Metrics</span><span class="trail-arr">&#8250;</span><span class="trail-step ts-next">03 Sources</span><span class="trail-arr">&#8250;</span><span class="trail-step ts-next">04 Blocks</span><span class="trail-arr">&#8250;</span><span class="trail-step ts-next">07 Calls</span><span class="trail-arr">&#8250;</span><span class="trail-step ts-next">Complete Day</span></div>
  <div class="ey">Section 02</div>
  <div class="tlg" style="margin-bottom:6px;">Daily Metrics</div>
  <div style="font-size:13px;color:var(--muted);margin-bottom:18px;">Alex Rivera &#8212; Monday May 4 &#8212; End of day totals entered progressively throughout the day.</div>
  <div class="fm-section">
    <div class="fm-head"><span class="fm-head-lbl">02 &#8212; Daily Metrics</span><span class="fm-head-badge">COMPLETE</span></div>
    <div class="fm-body">
      <div class="fm-grid" style="grid-template-columns:repeat(3,1fr);gap:10px;">
        <div class="fm-field"><div class="fm-lbl">Total Calls Made</div><div class="fm-target">Target: 68</div><div class="fm-val hit">94</div><div class="fm-bar"><div class="fm-fill hit" style="width:100%"></div></div></div>
        <div class="fm-field"><div class="fm-lbl">Broker Conversations</div><div class="fm-target">Target: 12 by 11:30AM</div><div class="fm-val hit">12</div><div class="fm-bar"><div class="fm-fill hit" style="width:100%"></div></div></div>
